{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VOCA",
  "version": "0.1.0",
  "identifier": "com.b3mlabs.voca",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "orb",
        "title": "VOCA",
        "width": 80,
        "height": 80,
        "minWidth": 80,
        "minHeight": 80,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "x": 40,
        "y": 80
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": ["English"]
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "publisher": "B3M Labs",
    "copyright": "© 2026 Asman Mirza. MIT License.",
    "shortDescription": "Local-first floating dictation orb",
    "longDescription": "VOCA is a local-first, always-on-top floating dictation orb. Press a hotkey, speak, and your words appear in whatever window you were using — no cloud, no subscription."
  }
}
